{
  "info": {
    "name": "Expense Tracker API",
    "description": "Collection for testing all Expense Tracker API endpoints. Import the 'Expense-Tracker-API - Local' environment and select it in the top-right dropdown. After login or register, the `accessToken` is saved to the environment automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "expenseId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Root - API Running",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/",
            "description": "Check if the API server is running."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.environment.set('accessToken', json.accessToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Register a new user. Required: name, email, password. On success, accessToken is saved to the active environment for protected routes."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.environment.set('accessToken', json.accessToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login with email and password. Saves accessToken to the active environment. Refresh token is set in cookie (use same Postman environment/cookies for /refresh)."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/logout",
            "description": "Logout. Clears the refreshToken cookie."
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.accessToken) {",
                  "        pm.environment.set('accessToken', json.accessToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/api/auth/refresh",
            "description": "Get a new access token using the refreshToken cookie. Run Login first so the cookie is set (Postman sends cookies automatically for same domain)."
          }
        }
      ]
    },
    {
      "name": "Expense",
      "item": [
        {
          "name": "Create Expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.expense && json.expense._id) {",
                  "        pm.environment.set('expenseId', json.expense._id);",
                  "        pm.collectionVariables.set('expenseId', json.expense._id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Groceries\",\n  \"amount\": 85.50,\n  \"category\": \"Food\",\n  \"date\": \"2025-03-10\"\n}"
            },
            "url": "{{baseUrl}}/api/expense/create",
            "description": "Create an expense. Requires Bearer token (run Login or Register first). Required body: title, amount, category, date. On success, expenseId is saved for Get/Update/Delete by ID."
          }
        },
        {
          "name": "Get All Expenses",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/expense",
            "description": "Get all expenses for the logged-in user. Requires Bearer token."
          }
        },
        {
          "name": "Get Expense by ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/expense/{{expenseId}}",
            "description": "Get a single expense by ID. Set expenseId (e.g. from Create Expense response or Get All)."
          }
        },
        {
          "name": "Update Expense",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Groceries\",\n  \"amount\": 120.00,\n  \"category\": \"Food\",\n  \"date\": \"2025-03-10\"\n}"
            },
            "url": "{{baseUrl}}/api/expense/{{expenseId}}",
            "description": "Update an expense by ID. Set expenseId. Body: title, amount, category, date."
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/expense/{{expenseId}}",
            "description": "Delete an expense by ID. Set expenseId."
          }
        }
      ]
    }
  ]
}
